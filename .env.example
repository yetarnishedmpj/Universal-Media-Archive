# Database Configuration
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=strong_password_here
MONGO_URI=mongodb://admin:strong_password_here@mongodb:27017/

# Flask Configuration
FLASK_SECRET_KEY=generate_a_random_secret_key_here
FLASK_DEBUG=false

# Security & CORS
# Set to your domain (e.g., https://your-app.com, https://your-other-domain.com). Use * only for temporary testing.
ALLOWED_ORIGINS=*

# API Keys (Ingestion Scripts)
TMDB_API_KEY=your_tmdb_api_key_here
RAWG_API_KEY=your_rawg_api_key_here
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
YOUTUBE_API_KEY=your_youtube_api_key_here
